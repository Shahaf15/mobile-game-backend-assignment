{
  "info": {
    "name": "Mobile Game Backend API",
    "description": "API collection for the mobile game backend microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "playerId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Player Management",
      "item": [
        {
          "name": "Create Player",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('playerId', response.playerId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"player1\",\n  \"email\": \"player1@example.com\",\n  \"displayName\": \"Player One\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/players",
              "host": ["{{baseUrl}}"],
              "path": ["api", "players"]
            }
          }
        },
        {
          "name": "Get Player by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/players/{{playerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "players", "{{playerId}}"]
            }
          }
        },
        {
          "name": "Update Player",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"player1_updated\",\n  \"email\": \"player1_new@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/players/{{playerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "players", "{{playerId}}"]
            }
          }
        },
        {
          "name": "Delete Player",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/players/{{playerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "players", "{{playerId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Game Scores",
      "item": [
        {
          "name": "Submit Score",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"playerId\": \"{{playerId}}\",\n  \"score\": 1500\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/scores",
              "host": ["{{baseUrl}}"],
              "path": ["api", "scores"]
            }
          }
        },
        {
          "name": "Get Top Scores",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/scores/top?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "scores", "top"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Get Leaderboard (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/players/leaderboard?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "players", "leaderboard"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Log Management",
      "item": [
        {
          "name": "Submit Log (Info)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"playerId\": \"{{playerId}}\",\n  \"logData\": \"Player completed level 5\",\n  \"level\": \"info\",\n  \"action\": \"level_complete\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "logs"]
            }
          }
        },
        {
          "name": "Submit Log (Error)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"playerId\": \"{{playerId}}\",\n  \"logData\": \"Failed to load game assets\",\n  \"level\": \"error\",\n  \"action\": \"asset_load_failure\",\n  \"metadata\": {\n    \"assetType\": \"texture\",\n    \"assetName\": \"player_sprite.png\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "logs"]
            }
          }
        },
        {
          "name": "Submit Log (Fatal)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"playerId\": \"{{playerId}}\",\n  \"logData\": \"Application crash on startup\",\n  \"level\": \"fatal\",\n  \"action\": \"app_crash\",\n  \"metadata\": {\n    \"device\": \"iPhone 15\",\n    \"os\": \"iOS 18.2\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "logs"]
            }
          }
        }
      ]
    },
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "API Gateway Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    }
  ]
}
