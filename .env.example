# MongoDB
MONGODB_URI=mongodb://mongodb:27017/game-backend

# Redis
REDIS_URL=redis://redis:6379

# RabbitMQ
RABBITMQ_URL=amqp://rabbitmq:5672

# Service Ports
API_GATEWAY_PORT=3000
PLAYER_SERVICE_PORT=3001
SCORE_SERVICE_PORT=3002
LEADERBOARD_SERVICE_PORT=3003
LOG_SERVICE_PORT=3004

# Service URLs (for API Gateway)
PLAYER_SERVICE_URL=http://player-service:3001
SCORE_SERVICE_URL=http://score-service:3002
LEADERBOARD_SERVICE_URL=http://leaderboard-service:3003
LOG_SERVICE_URL=http://log-service:3004

# Log Worker Configuration
BATCH_SIZE=50
BATCH_TIMEOUT_MS=2000
RATE_LIMIT_MAX_TOKENS=100
RATE_LIMIT_REFILL_RATE=20
MAX_CONCURRENCY=3
PREFETCH_COUNT=100

# Leaderboard Cache
LEADERBOARD_CACHE_TTL=60

# Log Retention (seconds)
LOG_TTL_SECONDS=2592000
